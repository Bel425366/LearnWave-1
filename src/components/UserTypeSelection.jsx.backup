import { useState } from 'react'

const USER_TYPES = [
  { 
    id: 'aluno', 
    label: 'Aluno', 
    description: 'Acesse conteúdos e atividades',
    icon: (
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
        <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
        <path d="M6 12v5c3 3 9 3 12 0v-5"/>
      </svg>
    ),
    gradient: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)'
  },
  { 
    id: 'professor', 
    label: 'Professor', 
    description: 'Gerencie turmas e materiais',
    icon: (
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
    ),
    gradient: 'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)'
  },
  { 
    id: 'administrador', 
    label: 'Administrador', 
    description: 'Controle total da plataforma',
    icon: (
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
    ),
    gradient: 'linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)'
  }
]

function UserTypeSelection({ onSelectUserType }) {
  const [selectedType, setSelectedType] = useState('')

  const handleContinue = () => {
    if (selectedType) {
      onSelectUserType(selectedType)
    }
  }

  return (
    <div className="auth-container">
      <div className="user-selection-modern">
        <div className="selection-header">
          <div className="logo-circle">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" strokeWidth="2">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
          </div>
          <h1 className="selection-title">LearnWave</h1>
          <p className="selection-subtitle">Escolha como deseja acessar</p>
        </div>
        
        <div className="user-cards-grid">
          {USER_TYPES.map(type => (
            <div
              key={type.id}
              className={`user-card-modern ${selectedType === type.id ? 'selected' : ''}`}
              onClick={() => setSelectedType(type.id)}
              style={{'--card-gradient': type.gradient}}
            >
              <div className="card-icon-circle">{type.icon}</div>
              <h3 className="card-title">{type.label}</h3>
              <p className="card-description">{type.description}</p>
              <div className="card-check">
                {selectedType === type.id && '✓'}
              </div>
            </div>
          ))}
        </div>
        
        <button 
          className="btn-continue-modern" 
          onClick={handleContinue}
          disabled={!selectedType}
        >
          Continuar →
        </button>
      </div>
    </div>
  )
}

export default UserTypeSelection
